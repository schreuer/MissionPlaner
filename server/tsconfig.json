{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "paths": {
      "@mission-planer/shared": ["../shared/src"]
    }
  },
  "include": ["src"],
  "exclude": [],
  "references": [
    { "path": "../shared" }
  ]
}
